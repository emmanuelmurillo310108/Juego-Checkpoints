<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane prefHeight="550.0"
            prefWidth="850.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uniquindio.poo.universidad.viewController.VistaController"
            styleClass="root">
    <children>
        <HBox spacing="20"
              alignment="CENTER"
              AnchorPane.topAnchor="20"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20">
            <VBox spacing="15"
                  alignment="TOP_CENTER"
                  styleClass="panel-checkpoints">
                <padding>
                    <Insets top="100"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>
                <Label text="LISTA DE CHECKPOINTS"
                       styleClass="subtitulo"/>

                <ListView fx:id="listCheckpoints"
                          prefWidth="370"
                          prefHeight="280"
                          styleClass="checkpoint-list"/>
            </VBox>
            <VBox spacing="15"
                  alignment="CENTER"
                  styleClass="contenedor-principal">

                <padding>
                    <Insets top="20"
                            right="20"
                            bottom="20"
                            left="20"/>
                </padding>

                <Label text="Jueguito :b"
                       styleClass="titulo"/>

                <ImageView fx:id="imgGif"
                           fitWidth="180"
                           fitHeight="180"
                           preserveRatio="true">
                    <image>
                        <Image url="@images/pixel.gif"/>
                    </image>
                </ImageView>

                <Label fx:id="lblNivel"
                       text="Nivel: 1"
                       styleClass="info-label"/>

                <Label fx:id="lblVidas"
                       text="Vidas: 3"
                       styleClass="info-label"/>

                <Label fx:id="lblMonedas"
                       text="Monedas: 0"
                       styleClass="info-label"/>

                <Label fx:id="lblEstado"
                       text="JUGANDO"
                       styleClass="estado-label"/>

                <Button text="Subir Nivel"
                        prefWidth="220"
                        styleClass="game-button"
                        onAction="#subirNivel"/>

                <Button text="Perder Vida"
                        prefWidth="220"
                        styleClass="game-button"
                        onAction="#perderVida"/>

                <Button text="Ganar Monedas"
                        prefWidth="220"
                        styleClass="game-button"
                        onAction="#ganarMonedas"/>

                <Button text="Guardar Checkpoint"
                        prefWidth="220"
                        styleClass="game-button"
                        onAction="#guardarCheckpoint"/>

                <Button text="Restaurar Checkpoint"
                        prefWidth="220"
                        styleClass="game-button"
                        onAction="#restaurarCheckpoint"/>

                <Button text="Reiniciar Juego"
                        prefWidth="220"
                        styleClass="danger-button"
                        onAction="#reiniciarJuego"/>

                <Label fx:id="lblMensaje"
                       text=""
                       styleClass="mensaje-label"/>
            </VBox>
        </HBox>
    </children>
</AnchorPane>